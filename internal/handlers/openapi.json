{
  "openapi": "3.1.0",
  "info": {
    "title": "lpwallet",
    "description": "Loyalty Points Wallet API — Sanlam SFTX",
    "version": "1.0.0"
  },
  "servers": [{ "url": "http://127.0.0.1:8700" }],
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer" }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "code": { "type": "string" }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id_user": { "type": "integer" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "role": { "type": "string", "enum": ["member", "admin"] },
          "client_id": { "type": "string" },
          "client_secret": { "type": "string" }
        }
      },
      "UserInput": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "name": { "type": "string" },
          "email": { "type": "string" },
          "role": { "type": "string", "enum": ["member", "admin"] },
          "password": { "type": "string" },
          "client_id": { "type": "string" },
          "client_secret": { "type": "string" }
        }
      },
      "Account": {
        "type": "object",
        "properties": {
          "id_account": { "type": "integer" },
          "rid_user": { "type": "integer" },
          "name": { "type": "string" },
          "balance": { "type": "number" }
        }
      },
      "AccountInput": {
        "type": "object",
        "required": ["rid_user", "name"],
        "properties": {
          "rid_user": { "type": "integer" },
          "name": { "type": "string" },
          "balance": { "type": "number" }
        }
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "id_account_transaction": { "type": "integer" },
          "rid_account": { "type": "integer" },
          "action": { "type": "string", "enum": ["spend", "earn"] },
          "reference": { "type": "string" },
          "amount": { "type": "number" },
          "transaction_datetime": { "type": "string", "format": "date-time" }
        }
      },
      "TransactionInput": {
        "type": "object",
        "required": ["rid_account", "action", "reference"],
        "properties": {
          "rid_account": { "type": "integer" },
          "action": { "type": "string", "enum": ["spend", "earn"] },
          "reference": { "type": "string" },
          "amount": { "type": "number" },
          "transacted_at": { "type": "string", "format": "date-time", "description": "Defaults to now if omitted" }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string" },
          "password": { "type": "string" }
        }
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "authtoken": { "type": "string" },
          "expires_at": { "type": "string", "format": "date-time" }
        }
      },
      "AuditDetail": {
        "type": "object",
        "properties": {
          "id_audit_detail": { "type": "integer" },
          "column_name": { "type": "string" },
          "column_value": { "type": "string" },
          "rid_audit_detail": { "type": "integer" }
        }
      },
      "AuditEvent": {
        "type": "object",
        "properties": {
          "id_audit_event": { "type": "integer" },
          "action": { "type": "integer", "description": "1=create 2=update 3=delete" },
          "datetime": { "type": "string", "format": "date-time" },
          "rid_user": { "type": "integer" },
          "row_id": { "type": "integer" },
          "tablename": { "type": "string" },
          "relridauditdetailpublicauditdetails": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/AuditDetail" }
          }
        }
      },
      "AuditTableSummary": {
        "type": "object",
        "properties": {
          "table": { "type": "string" },
          "creates": { "type": "integer" },
          "updates": { "type": "integer" },
          "deletes": { "type": "integer" },
          "total": { "type": "integer" }
        }
      },
      "AuditUserSummary": {
        "type": "object",
        "properties": {
          "user_id": { "type": "integer" },
          "email": { "type": "string" },
          "total": { "type": "integer" }
        }
      },
      "AuditDaySummary": {
        "type": "object",
        "properties": {
          "date": { "type": "string", "format": "date" },
          "total": { "type": "integer" }
        }
      },
      "AuditReport": {
        "type": "object",
        "properties": {
          "from_date": { "type": "string", "format": "date-time" },
          "to_date": { "type": "string", "format": "date-time" },
          "total_events": { "type": "integer" },
          "by_table": { "type": "array", "items": { "$ref": "#/components/schemas/AuditTableSummary" } },
          "by_user": { "type": "array", "items": { "$ref": "#/components/schemas/AuditUserSummary" } },
          "by_day": { "type": "array", "items": { "$ref": "#/components/schemas/AuditDaySummary" } }
        }
      }
    }
  },
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/healthz": {
      "get": {
        "summary": "Health check",
        "security": [],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "type": "object", "properties": { "status": { "type": "string" } } } } } },
          "500": { "description": "DB unreachable", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/version": {
      "get": {
        "summary": "Version info",
        "security": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "version": { "type": "string" }, "db_version": { "type": "string" } } } } }
          }
        }
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "summary": "Login",
        "security": [],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LoginRequest" } } } },
        "responses": {
          "200": { "description": "Login successful", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LoginResponse" } } } },
          "401": { "description": "Invalid credentials", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/v1/auth/logout": {
      "post": {
        "summary": "Logout",
        "responses": {
          "204": { "description": "Session expired" },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/v1/users": {
      "get": {
        "summary": "List users (admin)",
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/User" } } } } },
          "403": { "description": "Forbidden", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "post": {
        "summary": "Create user (admin)",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UserInput" } } } },
        "responses": {
          "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/User" } } } },
          "400": { "description": "Invalid input", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "403": { "description": "Forbidden", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "409": { "description": "Email already exists", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/v1/users/{id}": {
      "get": {
        "summary": "Get user (admin or self)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/User" } } } },
          "403": { "description": "Forbidden", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "put": {
        "summary": "Update user (admin or self)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UserInput" } } } },
        "responses": {
          "200": { "description": "Updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/User" } } } },
          "400": { "description": "Invalid input", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "403": { "description": "Forbidden", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "delete": {
        "summary": "Delete user (admin)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "204": { "description": "Deleted" },
          "403": { "description": "Forbidden", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/v1/accounts": {
      "get": {
        "summary": "List accounts (member sees own; admin sees all)",
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Account" } } } } }
        }
      },
      "post": {
        "summary": "Create account (admin)",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AccountInput" } } } },
        "responses": {
          "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Account" } } } },
          "400": { "description": "Invalid input", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "403": { "description": "Forbidden", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/v1/accounts/{id}": {
      "get": {
        "summary": "Get account (owner or admin)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Account" } } } },
          "403": { "description": "Forbidden", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "put": {
        "summary": "Update account (admin)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AccountInput" } } } },
        "responses": {
          "200": { "description": "Updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Account" } } } },
          "403": { "description": "Forbidden", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "delete": {
        "summary": "Delete account (admin)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "204": { "description": "Deleted" },
          "403": { "description": "Forbidden", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/v1/transactions": {
      "get": {
        "summary": "List transactions for an account",
        "parameters": [{ "name": "account_id", "in": "query", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Transaction" } } } } },
          "403": { "description": "Forbidden", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "post": {
        "summary": "Capture a single transaction",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TransactionInput" } } } },
        "responses": {
          "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Transaction" } } } },
          "400": { "description": "Invalid input", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "409": { "description": "Duplicate reference or insufficient balance", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/v1/transactions/batch": {
      "post": {
        "summary": "Batch capture transactions (JSON)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["transactions"],
                "properties": {
                  "transactions": { "type": "array", "items": { "$ref": "#/components/schemas/TransactionInput" } }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "All transactions created", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Transaction" } } } } },
          "400": { "description": "Invalid input", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "409": { "description": "Duplicate reference or insufficient balance", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/v1/transactions/batch/csv": {
      "post": {
        "summary": "Batch capture transactions (CSV)",
        "description": "Upload a CSV with header `ref,account_id,kind,points,occurred_at`. `kind` must be `earn` or `spend`. `occurred_at` accepts RFC3339, `2006-01-02T15:04:05`, `2006-01-02 15:04:05`, or `2006-01-02`; defaults to now if empty. Rows are processed in order; first failure aborts and returns the row number.",
        "requestBody": {
          "required": true,
          "content": {
            "text/csv": {
              "schema": { "type": "string" },
              "example": "ref,account_id,kind,points,occurred_at\ntx-001,123,earn,150,2024-06-01T10:00:00\ntx-002,123,spend,50,2024-06-02T09:00:00"
            }
          }
        },
        "responses": {
          "201": { "description": "All rows captured", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Transaction" } } } } },
          "400": { "description": "Parse error or invalid row (includes row number)", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "409": { "description": "Duplicate reference or insufficient balance", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/v1/audit": {
      "get": {
        "summary": "List audit events (admin)",
        "description": "Returns audit_event rows with detail rows preloaded, newest first. All filters are optional.",
        "parameters": [
          { "name": "from", "in": "query", "schema": { "type": "string" }, "description": "Start datetime (RFC3339, 2006-01-02T15:04:05, or 2006-01-02)" },
          { "name": "to", "in": "query", "schema": { "type": "string" }, "description": "End datetime (inclusive)" },
          { "name": "table", "in": "query", "schema": { "type": "string" }, "description": "Filter by tablename (e.g. public.user)" },
          { "name": "user_id", "in": "query", "schema": { "type": "integer" }, "description": "Filter by rid_user" }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/AuditEvent" } } } } },
          "400": { "description": "Invalid filter param", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "403": { "description": "Forbidden", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/v1/audit/report": {
      "get": {
        "summary": "Audit activity report (admin)",
        "description": "Returns aggregated counts broken down by table, user, and day. Date filters are optional.",
        "parameters": [
          { "name": "from", "in": "query", "schema": { "type": "string" }, "description": "Start datetime (RFC3339, 2006-01-02T15:04:05, or 2006-01-02)" },
          { "name": "to", "in": "query", "schema": { "type": "string" }, "description": "End datetime (inclusive)" }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuditReport" } } } },
          "400": { "description": "Invalid filter param", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "403": { "description": "Forbidden", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/v1/transactions/{id}": {
      "get": {
        "summary": "Get transaction (owner or admin)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Transaction" } } } },
          "403": { "description": "Forbidden", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "delete": {
        "summary": "Delete transaction (admin)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "204": { "description": "Deleted" },
          "403": { "description": "Forbidden", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    }
  }
}
